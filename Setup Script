#!/bin/bash

echo "------------------------------------------------"
echo "TextLens: Azerbaijani OCR Setup for Mac"
echo "------------------------------------------------"

# 1. Check for Homebrew
if ! command -v brew &> /dev/null; then
    echo "Homebrew not found. Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
else
    echo "✓ Homebrew is already installed."
fi

# 2. Install System Dependencies
echo "Installing Tesseract and Poppler (this may take a few minutes)..."
brew install tesseract tesseract-lang poppler

# 3. Setup Python Virtual Environment
echo "Setting up Python environment..."
python3 -m venv venv
source venv/bin/activate

# 4. Install Python Packages
echo "Installing Python dependencies..."
pip install Flask pytesseract Pillow pdf2image gunicorn

echo ""
echo "------------------------------------------------"
echo "SETUP COMPLETE!"
echo "To start the app in the future, run:"
echo "source venv/bin/activate && python3 local_app.py"
echo "------------------------------------------------"

# Launch the app immediately for the first time
python3 local_app.py
